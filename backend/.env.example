# --- Hermes Mobile Bridge config ---
# Copy to .env and edit.

# hermes-webui (loopback, on the same host)
WEBUI_BASE_URL=http://127.0.0.1:8787
WEBUI_PASSWORD=

# Long random bearer the iPhone stores in Keychain.
# Generate:  python3 -c 'import secrets;print(secrets.token_hex(32))'
MOBILE_TOKEN=change-me-to-a-long-random-hex

# SQLite path for the runs registry
RUNS_DB_PATH=./runs.sqlite

# Public bind for the bridge (behind Cloudflare Tunnel)
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080

# Optional overrides
WEBUI_LOGIN_RETRIES=3
SSE_PROXY_WRITE_DEADLINE_SECONDS=120

# APNs (v1.1 — leave blank in v1)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_PATH=
APNS_TOPIC=com.hermes.mobile
APNS_USE_SANDBOX=1